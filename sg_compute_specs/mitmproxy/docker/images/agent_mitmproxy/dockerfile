# ═══════════════════════════════════════════════════════════════════════════════
# Agent Mitmproxy — container image
#
# One image running two processes under supervisord:
#   • mitmweb on 0.0.0.0:8080 (proxy) + 127.0.0.1:8081 (web UI)
#   • uvicorn on 0.0.0.0:8000 (admin FastAPI)
#
# Build context is the repo root:
#   docker build -f agent_mitmproxy/docker/images/agent_mitmproxy/dockerfile .
# All COPY paths below are relative to that root.
# ═══════════════════════════════════════════════════════════════════════════════

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        supervisor ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY agent_mitmproxy/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Source layout: the whole agent_mitmproxy/ package (addons + consts + fast_api +
# schemas + version) ships to /app/agent_mitmproxy/. supervisord.conf +
# entrypoint.sh land directly under /app/ so supervisord finds its config and
# the container's CMD resolves.
COPY agent_mitmproxy/                                               ./agent_mitmproxy/
COPY agent_mitmproxy/docker/images/agent_mitmproxy/supervisord.conf ./supervisord.conf
COPY agent_mitmproxy/docker/images/agent_mitmproxy/entrypoint.sh    ./entrypoint.sh
RUN chmod +x /app/entrypoint.sh

ENV PYTHONPATH=/app

EXPOSE 8080 8000

CMD ["/app/entrypoint.sh"]
