# ═══════════════════════════════════════════════════════════════════════════════
# Vault App Stack — .env.example
# Copy to .env and fill in values before running docker compose.
# ═══════════════════════════════════════════════════════════════════════════════

# ECR registry (without trailing slash)
ECR_REGISTRY=<aws_account_id>.dkr.ecr.<region>.amazonaws.com

# Image tag — uses 'latest' when blank
IMAGE_TAG=latest

# Single stack-wide auth secret (shared by host-plane and playwright service)
FAST_API__AUTH__API_KEY__NAME=X-API-Key
FAST_API__AUTH__API_KEY__VALUE=change-me

# sg-send-vault access token — gates the vault UI and API
SGRAPH_SEND__ACCESS_TOKEN=change-me

# Storage mode for sg-send-vault: disk | memory | s3
SEND__STORAGE_MODE=disk

# Host path for vault data (disk mode only)
VAULT_DATA_PATH=/opt/vault-app/data

# Optional: comma-separated vault keys to clone into the vault on first boot
# SG_VAULT_APP__SEED_VAULT_KEYS=key1,key2,key3

# Optional: watchdog timeout for playwright (milliseconds)
# SG_PLAYWRIGHT__WATCHDOG_MAX_REQUEST_MS=120000
