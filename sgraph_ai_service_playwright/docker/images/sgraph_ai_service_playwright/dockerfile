# ═══════════════════════════════════════════════════════════════════════════════
# SG Playwright Service — Docker image (v0.1.28 — S3-zip hot-swap)
#
# Base:        Microsoft Playwright (includes Chromium + system deps)
# Integration: AWS Lambda Web Adapter (FastAPI ↔ Lambda events)
# Entrypoint:  lambda_entry.py (boot shim) — resolves code from S3 zip, local
#              mount, or baked sys.path, then starts uvicorn on port 8000.
#
# The image holds:
#   • lambda_entry.py — the boot shim; baked in, never hot-swapped
#   • image_version   — exposed at /var/task/image_version, read by the shim
#   • requirements.txt + a snapshot of the code — baseline fallback when no
#     S3 override is pinned via AGENTIC_APP_VERSION.
#
# Refreshed from OSBot-Playwright v0.6.10:
#   Playwright 1.40.0 → 1.58.0   (latest published noble tag at time of writing)
#   Ubuntu jammy → noble
#   LWA 0.7.1 → 1.0.0
# ═══════════════════════════════════════════════════════════════════════════════

FROM mcr.microsoft.com/playwright/python:v1.58.0-noble

COPY --from=public.ecr.aws/awsguru/aws-lambda-adapter:1.0.0 \
     /lambda-adapter /opt/extensions/lambda-adapter
ENV PORT=8000

WORKDIR /var/task
COPY    requirements.txt ./
RUN     python -m pip install -r requirements.txt --break-system-packages
RUN     python -c 'import playwright; print("playwright", playwright.__version__, "ok")'
COPY    . ./

CMD     exec python3 lambda_entry.py
