{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "SG Playwright service — request rates, latency histograms, and Chromium lifecycle timings.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(sg_playwright_request_total[5m])",
          "legendFormat": "{{endpoint}} / {{status}}"
        }
      ],
      "title": "Request rate (5m avg)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"legend": {"calcs": ["mean", "p95"], "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, rate(sg_playwright_total_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, rate(sg_playwright_total_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, rate(sg_playwright_total_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "title": "Total request duration (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2}, "unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, rate(sg_playwright_chromium_launch_seconds_bucket[5m]))",
          "legendFormat": "p95 launch"
        }
      ],
      "title": "Chromium launch p95 (s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2}, "unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "id": 4,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, rate(sg_playwright_navigate_seconds_bucket[5m]))",
          "legendFormat": "p95 navigate"
        }
      ],
      "title": "Navigate p95 (s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2}, "unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "id": 5,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, rate(sg_playwright_chromium_teardown_seconds_bucket[5m]))",
          "legendFormat": "p95 teardown"
        }
      ],
      "title": "Chromium teardown p95 (s)",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["sg-playwright", "performance"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "SG Playwright — Request Performance",
  "uid": "sg-playwright-perf",
  "version": 1
}
