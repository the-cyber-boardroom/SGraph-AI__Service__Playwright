{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0"},
    {"type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Docker container logs via Loki/Promtail — browse and search all sg-playwright stack log output.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "{job=\"containerlogs\", container_name=\"sg-playwright-playwright-1\"} |= `${search}`",
          "legendFormat": ""
        }
      ],
      "title": "playwright service logs",
      "type": "logs"
    },
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 5},
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
