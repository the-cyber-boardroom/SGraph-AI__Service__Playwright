      "type": "logs"
    },
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 10},
