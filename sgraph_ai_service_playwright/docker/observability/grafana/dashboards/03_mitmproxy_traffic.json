{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "agent_mitmproxy — proxied flow counts, durations, byte throughput, and status class distribution.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(sg_mitmproxy_flows_total[5m])",
          "legendFormat": "{{scheme}} / {{status_class}}"
        }
      ],
      "title": "Flow rate by scheme + status class (5m avg)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2}, "unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, rate(sg_mitmproxy_flow_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, rate(sg_mitmproxy_flow_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, rate(sg_mitmproxy_flow_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "title": "Flow duration (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2}, "unit": "binBps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(sg_mitmproxy_bytes_request_total[5m])",
          "legendFormat": "request bytes/s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(sg_mitmproxy_bytes_response_total[5m])",
          "legendFormat": "response bytes/s"
        }
      ],
      "title": "Byte throughput (request vs response)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "options": {"pieType": "donut", "legend": {"displayMode": "table", "placement": "right", "calcs": ["sum"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "increase(sg_mitmproxy_flows_total[1h])",
          "legendFormat": "{{status_class}}"
        }
      ],
      "title": "Status class distribution (last 1h)",
      "type": "piechart"
    }
  ],
  "schemaVersion": 39,
  "tags": ["sg-playwright", "mitmproxy", "traffic"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "SG Playwright — Mitmproxy Traffic",
  "uid": "sg-mitmproxy-traffic",
  "version": 1
}
