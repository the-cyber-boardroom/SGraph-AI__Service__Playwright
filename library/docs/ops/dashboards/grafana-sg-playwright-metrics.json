{
  "__inputs": [
    {
      "name": "DS_AMP",
      "label": "Amazon Managed Prometheus",
      "description": "AMP data source — use grafana-amazonprometheus-datasource with SigV4 + Workspace IAM Role, region eu-west-2",
      "type": "datasource",
      "pluginId": "grafana-amazonprometheus-datasource",
      "pluginName": "Amazon Managed Service for Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-amazonprometheus-datasource",
      "name": "Amazon Managed Service for Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "SG Playwright EC2 stack — container and host metrics from cadvisor and node-exporter via AMP. External label: stack=sg-playwright.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Fleet Status",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" }, "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Instances Up",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
          "expr": "count(up{stack=\"sg-playwright\", job=\"prometheus\"} == 1)",
          "legendFormat": "UP",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 20, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Active Instances",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
          "expr": "up{stack=\"sg-playwright\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Container CPU",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "percentunit",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 3,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Container CPU Usage (5m rate)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
          "expr": "rate(container_cpu_usage_seconds_total{stack=\"sg-playwright\", container_label_com_docker_compose_service!=\"\", id!=\"/\"}[$__rate_interval])",
          "legendFormat": "{{container_label_com_docker_compose_service}} / {{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Container Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "bytes",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 4,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Container Memory Usage",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
          "expr": "container_memory_usage_bytes{stack=\"sg-playwright\", container_label_com_docker_compose_service!=\"\", id!=\"/\"}",
          "legendFormat": "{{container_label_com_docker_compose_service}} / {{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Host Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "bytes",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Host Free Memory",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
          "expr": "node_memory_MemAvailable_bytes{stack=\"sg-playwright\"}",
          "legendFormat": "available / {{instance}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
          "expr": "node_memory_MemTotal_bytes{stack=\"sg-playwright\"}",
          "legendFormat": "total / {{instance}}",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.85 }] },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "Root Disk Used %",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
          "expr": "1 - node_filesystem_avail_bytes{stack=\"sg-playwright\", mountpoint=\"/\"} / node_filesystem_size_bytes{stack=\"sg-playwright\", mountpoint=\"/\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Host CPU Usage (5m rate, all cores)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
          "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{stack=\"sg-playwright\", mode=\"idle\"}[$__rate_interval]))",
          "legendFormat": "cpu / {{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Network",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 5 },
          "unit": "Bps",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Container Network Receive (5m rate)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
          "expr": "rate(container_network_receive_bytes_total{stack=\"sg-playwright\", container_label_com_docker_compose_service!=\"\"}[$__rate_interval])",
          "legendFormat": "rx / {{container_label_com_docker_compose_service}} / {{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 5 },
          "unit": "Bps",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Container Network Transmit (5m rate)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-amazonprometheus-datasource", "uid": "${DS_AMP}" },
          "expr": "rate(container_network_transmit_bytes_total{stack=\"sg-playwright\", container_label_com_docker_compose_service!=\"\"}[$__rate_interval])",
          "legendFormat": "tx / {{container_label_com_docker_compose_service}} / {{instance}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["sg-playwright", "amp", "containers"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SG Playwright — Container & Host Metrics",
  "uid": "sg-playwright-metrics",
  "version": 1,
  "weekStart": ""
}
