# ═══════════════════════════════════════════════════════════════════════════════
# SG Playwright — .env.example
#
# Copy to .env and fill in your values before running docker compose up.
# The .env file is gitignored — never commit real secrets.
#
# ECR login (run once per session or when token expires):
#   aws ecr get-login-password --region <region> \
#     | docker login --username AWS --password-stdin <ECR_REGISTRY>
# ═══════════════════════════════════════════════════════════════════════════════

# ─── ECR / image ─────────────────────────────────────────────────────────────
ECR_REGISTRY=<account>.dkr.ecr.<region>.amazonaws.com
IMAGE_TAG=latest

# ─── Shared API key (Playwright API + sidecar admin API) ─────────────────────
FAST_API__AUTH__API_KEY__NAME=X-API-Key
FAST_API__AUTH__API_KEY__VALUE=change-me

# ─── Playwright tuning (optional — defaults shown) ───────────────────────────
# SG_PLAYWRIGHT__WATCHDOG_MAX_REQUEST_MS=120000

# ─── Sidecar upstream forwarding (optional — omit to run in direct mode) ─────
# AGENT_MITMPROXY__UPSTREAM_URL=http://corporate-proxy:3128
# AGENT_MITMPROXY__UPSTREAM_USER=
# AGENT_MITMPROXY__UPSTREAM_PASS=
