# ═══════════════════════════════════════════════════════════════════════════════
# SG Playwright — .env.example
#
# Copy to .env and fill in your values before running docker compose up.
# The .env file is gitignored — never commit real secrets.
#
# On EC2 this file lives at /opt/sg-playwright/.env and is written by the
# instance user-data script at creation time. Docker Compose reads it
# automatically — no exports, no sed patching of docker-compose.yml needed.
#
# ECR login (run once per session or when token expires):
#   aws ecr get-login-password --region <region> \
#     | docker login --username AWS --password-stdin <ECR_REGISTRY>
# ═══════════════════════════════════════════════════════════════════════════════

# ─── ECR / image ─────────────────────────────────────────────────────────────
ECR_REGISTRY=<account>.dkr.ecr.<region>.amazonaws.com
IMAGE_TAG=latest

# ─── Shared API key (Playwright API + sidecar admin API) ─────────────────────
FAST_API__AUTH__API_KEY__NAME=X-API-Key
FAST_API__AUTH__API_KEY__VALUE=change-me

# ─── Playwright tuning (optional — defaults shown) ───────────────────────────
# SG_PLAYWRIGHT__WATCHDOG_MAX_REQUEST_MS=120000

# ─── Sidecar upstream proxy (leave blank for direct / no proxy) ──────────────
# On EC2 set these to route all browser traffic through an authenticated proxy.
# The sidecar handles upstream auth — Playwright only sees the local sidecar.
AGENT_MITMPROXY__UPSTREAM_URL=
AGENT_MITMPROXY__UPSTREAM_USER=
AGENT_MITMPROXY__UPSTREAM_PASS=
# AGENT_MITMPROXY__HTTP2=false        # uncomment to fix HTTP/2 InvalidBodyLengthError via upstream proxy
